{
  "name": "@mimo-ai/desktop",
  "version": "0.2.0",
  "description": "MiMoCode Desktop - AI-powered development tool",
  "author": "MiMoCode <mimo@xiaomi.com>",
  "description": "MiMoCode Desktop - AI-powered development tool",
  "author": "MiMoCode <mimo@xiaomi.com>",
  "license": "MIT",
  "private": true,
  "main": "./dist/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:renderer": "vite --config vite.renderer.config.ts",
    "build": "electron-vite build",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "package": "electron-builder --config electron-builder.json",
    "package:win": "electron-builder --win --config electron-builder.json",
    "package:mac": "electron-builder --mac --config electron-builder.json",
    "package:linux": "electron-builder --linux --config electron-builder.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mimo-ai/app": "workspace:*",
    "@mimo-ai/ui": "workspace:*",
    "@mimo-ai/sdk": "workspace:*"
  },
  "devDependencies": {
    "@tailwindcss/vite": "catalog:",
    "electron": "34.5.8",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "solid-js": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-solid": "catalog:"
  }
}
